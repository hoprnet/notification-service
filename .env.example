# Local development environment variables.
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and is never committed.

PORT=8080
RUST_LOG=info

# ── Keep ──────────────────────────────────────────────────────────────────────
# Base URL of the Keep instance. Used to build per-alert deep-links.
KEEP_BASE_URL=https://incidents.staging.hoprnet.link

# ── Environment ───────────────────────────────────────────────────────────────
# Logical name for this deployment. Appended to the Zulip topic: alerts-<name>
ENVIRONMENT_NAME=staging

# ── Zulip ─────────────────────────────────────────────────────────────────────
# Set to false to disable all Zulip API calls (dry-run mode). Defaults to true.
ZULIP_ENABLED=true

# How many days to keep a fingerprint→message-ID mapping in the in-memory store.
# After this period the eviction task removes the entry and the next alert for
# that fingerprint will open a fresh Zulip message. Defaults to 7.
MESSAGE_TTL_DAYS=7

ZULIP_EMAIL=bot@yourorg.zulipchat.com
ZULIP_API_KEY=your_api_key_here
ZULIP_HOST=yourorg.zulipchat.com

# Stream used when the alert namespace has no explicit mapping below.
ZULIP_DEFAULT_STREAM=Alerts

# JSON object mapping Kubernetes namespace names to Zulip stream names.
# Alerts from unlisted namespaces fall back to ZULIP_DEFAULT_STREAM.
# NOTE: must be a single line — dotenv does not support multi-line values.
ZULIP_NAMESPACE_STREAMS={"blokli":"Blokli","ctdapp":"Hoprd","core-team":"Hoprd","webapi-hoprnet-org":"Products","network-hoprnet-org":"Products","hose":"Hoprd"}